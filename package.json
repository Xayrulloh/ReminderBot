{
	"name": "namoz-vaqti-bot",
	"version": "5.0.0",
	"description": "Telegram bot for Islamic prayer time reminders with group support, Quran verses, and configurable notifications",
	"main": "server.js",
	"type": "commonjs",
	"author": "Xayrulloh <xayrullohabduvohidov713@gmail.com> Abdug'ani <a.toshmukhamedov@icloud.com>",
	"license": "MIT",
	"homepage": "https://github.com/Xayrulloh/ReminderBot#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/Xayrulloh/ReminderBot.git"
	},
	"scripts": {
		"prebuild": "rimraf dist",
		"copy-public": "cp -rv public dist/public/",
		"build": "pnpm run prebuild && tsc && pnpm run copy-public",
		"start": "TS_NODE_BASEURL=./dist node -r tsconfig-paths/register dist/server.js",
		"start:dev": "TS_NODE_BASEURL=./dist tsc-watch --outDir ./dist --onSuccess \"node --env-file=.env -r tsconfig-paths/register dist/server.js\"",
		"i18n:generate": "i18next-resources-for-ts interface -i ./translate -o ./types/resources.d.ts && pnpm check:fix types/resources.d.ts",
		"format": "prettier --write .",
		"check:fix": "biome check --write",
		"check": "biome check"
	},
	"dependencies": {
		"@grammyjs/auto-retry": "2.0.2",
		"adhan": "4.4.3",
		"axios": "1.13.6",
		"dayjs": "1.11.20",
		"discord.js": "14.25.1",
		"fastify": "5.8.2",
		"fuzzy": "0.1.3",
		"grammy": "1.41.1",
		"grammy-scenes": "10.2.0",
		"i18next": "25.9.0",
		"mongoose": "9.3.1",
		"node-cron": "4.2.1",
		"node-schedule": "2.1.1",
		"tsconfig-paths": "4.2.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@grammyjs/types": "3.25.0",
		"@types/node": "24.9.2",
		"@types/node-schedule": "2.1.8",
		"i18next-resources-for-ts": "2.0.2",
		"prettier": "3.8.1",
		"rimraf": "6.1.3",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": "24.x",
		"pnpm": "10.x"
	},
	"packageManager": "pnpm@10.32.1"
}
